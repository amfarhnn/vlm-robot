        <mxCell id="26" value="Mainly RGB/fisheye camera observations; wheel odometry used in some experiments" style="shape=rectangle;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=8;strokeColor=#666666;fontSize=11;fillColor=#f8f9fa;" vertex="1" parent="1">
