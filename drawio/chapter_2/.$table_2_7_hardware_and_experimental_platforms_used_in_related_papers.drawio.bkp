        <mxCell id="24" value="Training data from TurtleBot2, Clearpath Jackal, Warthog, Spot, Yamaha Viking ATV, RC car, and cars; evaluation on LoCoBot, Vizbot, Unitree Go1, and Jackal" style="shape=rectangle;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=8;strokeColor=#666666;fontSize=11;fillColor=#f8f9fa;" vertex="1" parent="1">
