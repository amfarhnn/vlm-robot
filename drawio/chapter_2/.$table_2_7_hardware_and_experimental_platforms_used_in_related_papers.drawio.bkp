        <mxCell id="34" value="Simulation benchmarks and real-world experiments" style="shape=rectangle;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=8;strokeColor=#666666;fontSize=11;fillColor=#f8f9fa;" vertex="1" parent="1">
          <mxGeometry x="180" y="427" width="693" height="53" as="geometry" />
        </mxCell>
        <mxCell id="35" value="Exact robot platform and board are not stated in the main public summary; model is a video-based VLM" style="shape=rectangle;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=8;strokeColor=#666666;fontSize=11;fillColor=#f8f9fa;" vertex="1" parent="1">
          <mxGeometry x="873" y="427" width="693" height="53" as="geometry" />
        </mxCell>
        <mxCell id="36" value="Monocular RGB video stream only; no map, odometer, or depth input required" style="shape=rectangle;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=8;strokeColor=#666666;fontSize=11;fillColor=#f8f9fa;" vertex="1" parent="1">
          <mxGeometry x="1566" y="427" width="693" height="53" as="geometry" />
        </mxCell>
        <mxCell id="37" value="Relevant because it reduces hardware requirements to an RGB camera, making it attractive for a low-cost prototype." style="shape=rectangle;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=8;strokeColor=#666666;fontSize=11;fillColor=#f8f9fa;" vertex="1" parent="1">
