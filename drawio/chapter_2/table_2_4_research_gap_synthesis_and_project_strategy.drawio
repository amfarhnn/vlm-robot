        <mxCell id="17" value="Treat RGB-D mapping and scene graphs as future work" style="shape=rectangle;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=8;strokeColor=#666666;fontSize=11;fillColor=#f8f9fa;" vertex="1" parent="1">
          <mxGeometry x="877" y="321" width="706" height="40" as="geometry" />
